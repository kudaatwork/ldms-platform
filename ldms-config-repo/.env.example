# Copy to .env (never commit .env). Services and Config Server read these at runtime.
DB_USERNAME=root
DB_PASSWORD=your-mysql-password
MYSQL_USER=developer
MYSQL_PASSWORD=your-mysql-password
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=ldms_audit_trail_dev_db
JWT_SECRET=generate-with-openssl-rand-base64-64
RABBITMQ_USERNAME=admin
RABBITMQ_PASSWORD=admin
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_WHATSAPP_FROM=+14155238886
SENDGRID_API_KEY=SG.xxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@projectlx.co.zw
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=eu-north-1
FIREBASE_SERVER_KEY=your-firebase-server-key
MQTT_USERNAME=admin
MQTT_PASSWORD=admin
FILE_SERVICE_TOKEN=generate-with-uuidgen
ZIPKIN_URL=http://localhost:9411/api/v2/spans

# Config Server — Git backend (required for ldms-config-server; no file:// for prod)
LDMS_CONFIG_GIT_URI=https://github.com/your-org/ldms-config-repo.git
LDMS_CONFIG_GIT_BRANCH=main

# Basic auth for Spring Cloud Config clients calling ldms-config-server :8888
CONFIG_SERVER_USERNAME=config-user
CONFIG_SERVER_PASSWORD=changeme

# Eureka registry URL (include credentials if Eureka dashboard security is enabled)
# Example: http://eureka:changeme@localhost:8761/eureka/
EUREKA_URL=http://localhost:8761/eureka/

# Eureka dashboard (ldms-eureka-server basic auth)
EUREKA_DASHBOARD_USER=eureka
EUREKA_DASHBOARD_PASSWORD=changeme
EUREKA_HOSTNAME=localhost

# Private Git: use username/token (HTTPS) or SSH URI + host key; see Spring Cloud Config docs
# LDMS_CONFIG_GIT_USERNAME=
# LDMS_CONFIG_GIT_PASSWORD=

# Optional: host where config server runs (clients)
CONFIG_SERVER_HOST=localhost
