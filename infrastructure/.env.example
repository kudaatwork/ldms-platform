# Copy to .env in this directory before running docker compose.
# Never commit real secrets.

# ── MySQL 8.0 ────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=Mysql123!
MYSQL_DEVELOPER_PASSWORD=Password098()!

# ── RabbitMQ 3.13 (management UI: http://localhost:15672) ────
RABBITMQ_DEFAULT_USER=developer
RABBITMQ_DEFAULT_PASS=Password098()!

# ── Grafana (UI: http://localhost:3000) ──────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=Grafana098()!

# ── SonarQube + PostgreSQL (UI: http://localhost:9000) ───────
SONAR_DB_PASSWORD=Sonar098()!

# ── ldms-file-service internal API token ─────────────────────
# Generate securely:
#   openssl rand -hex 32
FILE_SERVICE_INTERNAL_TOKEN=dev-token-change-me

# ── RustFS (S3 + RustFS Console UI) ──────────────────────────
# RustFS Console UI: http://localhost:9005
# RustFS S3 API endpoint (host): http://localhost:9004
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin-change-me
S3_BUCKET=ldms-files
S3_REGION=us-east-1

# ── Auth management: Google Sign-In (optional) ───────────────
# Set GOOGLE_OAUTH_ENABLED=true and GOOGLE_CLIENT_ID to the OAuth 2.0 Web client ID from Google Cloud Console.
# GOOGLE_OAUTH_ENABLED=false
# GOOGLE_CLIENT_ID=
