  "emailSubject": "Reset Your ProjectLX Password - Action Required",
  "emailBodyHtml": "<!DOCTYPE html><html lang=\"en\"><head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"><title>Reset Your ProjectLX Password</title></head><body style=\"margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh;\"><table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"100%\" style=\"background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 20px 0;\"><tr><td align=\"center\"><table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" width=\"600\" style=\"max-width: 600px; background: #ffffff; border-radius: 20px; box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1); overflow: hidden;\"><tr><td style=\"background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%); color: white; padding: 40px 30px; text-align: center;\"><div style=\"margin-bottom: 20px;\"><div style=\"font-size: 32px; font-weight: 700; letter-spacing: -1px; display: inline-flex; align-items: center; gap: 10px;\"><div style=\"width: 40px; height: 40px; background: rgba(255, 255, 255, 0.2); border-radius: 10px; display: inline-flex; align-items: center; justify-content: center;\">🔒</div>ProjectLX</div></div><div style=\"font-size: 16px; font-weight: 300; opacity: 0.9; margin-top: 10px;\">Password Reset Request</div></td></tr><tr><td style=\"padding: 40px 30px; background: white;\"><div style=\"background: linear-gradient(135deg, #ffebee 0%, #ffc1cc 100%); border: 1px solid #e74c3c; border-radius: 12px; padding: 20px; margin-bottom: 30px; text-align: center;\"><div style=\"font-size: 18px; font-weight: 600; color: #c0392b; margin-bottom: 10px;\">🔐 Password Reset Requested</div><div style=\"font-size: 14px; color: #a93226;\">Someone requested a password reset for your ProjectLX logistics account</div></div><div style=\"font-size: 18px; font-weight: 600; color: #1e3c72; margin-bottom: 20px;\">Hello {{firstName}},</div><div style=\"font-size: 16px; color: #5a6c7d; margin-bottom: 30px; line-height: 1.7;\">We received a request to reset the password for your ProjectLX logistics account. If you made this request, click the button below to create a new password.</div><div style=\"background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%); border-radius: 15px; padding: 25px; margin: 30px 0; border-left: 4px solid #e74c3c;\"><div style=\"font-size: 16px; font-weight: 600; color: #1e3c72; margin-bottom: 15px;\">📧 Account Information</div><div style=\"display: flex; align-items: center; margin-bottom: 10px; font-size: 14px; color: #4a5568;\"><span style=\"font-weight: 500; width: 80px; color: #2d3748;\">Username:</span><span style=\"font-weight: 400; flex: 1;\">{{userName}}</span></div><div style=\"display: flex; align-items: center; margin-bottom: 10px; font-size: 14px; color: #4a5568;\"><span style=\"font-weight: 500; width: 80px; color: #2d3748;\">Email:</span><span style=\"font-weight: 400; flex: 1;\">{{Email}}</span></div></div><div style=\"text-align: center; margin: 40px 0;\"><div style=\"font-size: 16px; color: #4a5568; margin-bottom: 25px; line-height: 1.6;\">Click the button below to reset your password:</div><a href=\"{{resetLink}}\" style=\"display: inline-block; background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%); color: white; padding: 16px 40px; text-decoration: none; border-radius: 50px; font-weight: 600; font-size: 16px; letter-spacing: 0.5px; box-shadow: 0 8px 25px rgba(231, 76, 60, 0.3);\">🔐 Reset My Password →</a></div><div style=\"background: linear-gradient(135deg, #fff3cd 0%, #ffeaa7 100%); border: 1px solid #ffc107; border-radius: 12px; padding: 15px 20px; margin: 30px 0; font-size: 14px; color: #856404; text-align: center;\">⏰ This reset link expires in 24 hours for your security.</div><div style=\"background: #f8fafc; border-radius: 15px; padding: 25px; margin: 30px 0;\"><div style=\"font-size: 16px; font-weight: 600; color: #1e3c72; margin-bottom: 15px;\">🛡️ Security Information:</div><div style=\"font-size: 14px; color: #4a5568; line-height: 1.8;\">• If you didn't request this reset, please ignore this email<br>• Your password remains unchanged until you create a new one<br>• Always use a strong, unique password for your account<br>• Never share your password with anyone</div></div></td></tr><tr><td style=\"background: linear-gradient(135deg, #2d3748 0%, #1a202c 100%); color: #e2e8f0; padding: 30px; text-align: center;\"><div style=\"margin-bottom: 20px; padding: 20px; background: rgba(255, 255, 255, 0.05); border-radius: 12px;\"><div style=\"font-size: 14px; font-weight: 600; margin-bottom: 8px;\">🆘 Need Assistance?</div><div style=\"font-size: 14px;\">Contact our support team at <a href=\"mailto:support@projectlx.co.zw\" style=\"color: #81e6d9; text-decoration: none; font-weight: 500;\">support@projectlx.co.zw</a></div></div><div style=\"font-size: 12px; color: #a0aec0; margin-bottom: 20px; line-height: 1.5;\">If you didn't request this password reset, please ignore this email. Your account remains secure and no changes have been made.</div><div style=\"font-size: 14px; font-weight: 500;\">Best regards,<br><strong>The ProjectLX Security Team</strong><div style=\"font-size: 12px; color: #718096; margin-top: 8px; font-style: italic;\">🇿🇼 Securing Logistics in Zimbabwe</div></div></td></tr></table></td></tr></table></body></html>",
